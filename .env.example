# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# .env is loaded by compose.yaml's kontinuum-dev service (env_file) and is
# gitignored — real values only ever live locally.

# OIDC authentication (bearer-token validation on the API + the /app UI's
# PKCE login flow). Leave KONTINUUM_OIDC_ISSUER_URL empty to disable OIDC
# entirely and keep the current anonymous/always-allow behavior.
#
# KONTINUUM_OIDC_ADMIN_GROUPS is required once OIDC is enabled: it's a
# comma-delimited list of groups granted full (system:masters-equivalent)
# access. Every other group has no access. The server refuses to start with
# OIDC enabled and no admin groups configured, since that would lock
# everyone out.
KONTINUUM_OIDC_ISSUER_URL=https://auth.nicklasfrahm.dev
KONTINUUM_OIDC_CLIENT_ID=kontinuum
KONTINUUM_OIDC_REDIRECT_URL=http://localhost:8080/app
KONTINUUM_OIDC_ADMIN_GROUPS=nicklasfrahm-dev:platform
